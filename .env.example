# ─────────────────────────────────────────────────────────────────────────────
# FISCORD — Variables de Entorno
# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo como .env en el directorio correspondiente:
#   Backend → apps/backend/.env
#   Frontend → apps/web/.env  (solo las variables VITE_*)
#
# NUNCA subas .env al repositorio. Está en .gitignore.
# ─────────────────────────────────────────────────────────────────────────────


# ─────────────────────────────────────────────────────────────────────────────
# APLICACIÓN
# ─────────────────────────────────────────────────────────────────────────────

# Entorno de ejecución: development | production | test
NODE_ENV=development

# Puerto en que escucha el servidor Express
PORT=3000

# URL pública del backend (sin slash final)
APP_URL=http://localhost:3000

# URL pública del frontend web (para CORS y links en emails)
FRONTEND_URL=http://localhost:5173


# ─────────────────────────────────────────────────────────────────────────────
# POSTGRESQL — Railway
# ─────────────────────────────────────────────────────────────────────────────
# Cadena de conexión completa a PostgreSQL.
# En Railway: panel del proyecto → PostgreSQL → Connect → Connection String
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/fiscord

# Tamaño del pool de conexiones Prisma (recomendado: 5-10 en Railway free tier)
DATABASE_POOL_SIZE=5


# ─────────────────────────────────────────────────────────────────────────────
# REDIS — Railway
# ─────────────────────────────────────────────────────────────────────────────
# Cadena de conexión a Redis.
# En Railway: panel del proyecto → Redis → Connect → Connection String
# Usado para: sesiones, refresh tokens revocados y caché de dashboard
REDIS_URL=redis://USER:PASSWORD@HOST:PORT


# ─────────────────────────────────────────────────────────────────────────────
# JWT — JSON Web Tokens
# ─────────────────────────────────────────────────────────────────────────────
# Secreto para firmar los access tokens (corta duración).
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=reemplaza_con_256_bits_aleatorios

# Secreto para firmar los refresh tokens (larga duración).
# Debe ser DIFERENTE al access secret.
JWT_REFRESH_SECRET=reemplaza_con_otro_256_bits_aleatorios

# Duración del access token (formato ms/zeit: 15m, 1h, 1d)
JWT_ACCESS_EXPIRES=15m

# Duración del refresh token antes de expirar
JWT_REFRESH_EXPIRES=30d


# ─────────────────────────────────────────────────────────────────────────────
# BCRYPT
# ─────────────────────────────────────────────────────────────────────────────
# Número de rounds para el hash de contraseñas.
# 12 es el mínimo recomendado para producción. No bajar de 10.
BCRYPT_ROUNDS=12


# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE STORAGE — Almacenamiento de fotos de facturas
# ─────────────────────────────────────────────────────────────────────────────
# URL del proyecto Supabase.
# En Supabase: Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clave de servicio con permisos completos de Storage (NO la anon key).
# En Supabase: Settings → API → service_role key
# ADVERTENCIA: nunca exponer esta clave en el frontend.
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Nombre del bucket en Supabase Storage donde se guardan las fotos
# El bucket debe ser privado (no público)
SUPABASE_BUCKET=facturas


# ─────────────────────────────────────────────────────────────────────────────
# AMAZON SES — Envío de emails transaccionales
# ─────────────────────────────────────────────────────────────────────────────
# Región AWS donde está configurado SES
# Recomendado: us-east-1 (mayor disponibilidad)
AWS_REGION=us-east-1

# Credenciales del IAM user con permisos SES (ses:SendEmail, ses:SendRawEmail).
# En AWS: IAM → Users → Security credentials → Create access key
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Dirección de remitente verificada en SES.
# El dominio debe estar verificado en SES antes de usarse en producción.
SES_FROM_EMAIL=noreply@fiscord.app


# ─────────────────────────────────────────────────────────────────────────────
# CIFRADO AES-256 — Datos sensibles en reposo
# ─────────────────────────────────────────────────────────────────────────────
# Clave de 32 bytes en hexadecimal para cifrado AES-256.
# Genera una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_256_KEY=reemplaza_con_64_caracteres_hex


# ─────────────────────────────────────────────────────────────────────────────
# SENTRY — Monitoreo de errores
# ─────────────────────────────────────────────────────────────────────────────
# DSN del proyecto en Sentry para el backend.
# En Sentry: Project Settings → Client Keys → DSN
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oXXXXX.ingest.sentry.io/XXXXXXX


# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND WEB — Variables Vite (prefijo VITE_ obligatorio)
# ─────────────────────────────────────────────────────────────────────────────
# Solo estas variables van en apps/web/.env
# Las variables VITE_* son visibles en el bundle del cliente — no poner secretos.

# URL base de la API backend (sin slash final)
VITE_API_URL=http://localhost:3000

# DSN de Sentry para el frontend (puede ser el mismo proyecto o uno separado)
VITE_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oXXXXX.ingest.sentry.io/XXXXXXX
